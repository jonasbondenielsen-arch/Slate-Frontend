{
  "headers": [
    {
      "source": "/public/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "api/chat.js":        {"maxDuration": 30},
    "api/hrslate-chat.js":{"maxDuration": 30},
    "api/booking.js":     {"maxDuration": 10},
    "api/upload.js":      {"maxDuration": 30},
    "api/auth.js":        {"maxDuration": 15},
    "api/data.js":        {"maxDuration": 10}
  }
}
